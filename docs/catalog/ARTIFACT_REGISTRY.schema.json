{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CVF-Ecosystem/CVF-Operations-Workspace/raw/main/docs/catalog/ARTIFACT_REGISTRY.schema.json",
  "title": "CVF Operations Workspace Artifact Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "projectName", "artifactTypes", "statusLegend", "artifacts", "claimBoundary"],
  "properties": {
    "schemaVersion": {"const": "1.0"},
    "projectName": {"const": "CVF-Operations-Workspace"},
    "description": {"type": "string", "minLength": 1},
    "artifactTypes": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
    "statusLegend": {"type": "object", "minProperties": 1, "additionalProperties": {"type": "string", "minLength": 1}},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "path", "type", "status", "authority", "entrypoint", "summary", "related"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "title": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1, "pattern": "^[^\\\\]+$"},
          "type": {"type": "string", "minLength": 1},
          "status": {"type": "string", "minLength": 1},
          "authority": {"type": "string", "minLength": 1},
          "entrypoint": {"type": "boolean"},
          "summary": {"type": "string", "minLength": 1},
          "related": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
        }
      }
    },
    "claimBoundary": {"type": "string", "minLength": 1}
  }
}
